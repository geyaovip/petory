# Copy to server/.env
# Local dev: run `npm run db:up` first (Docker PostgreSQL)
# Host 5433 avoids conflict with other Postgres on 5432 (e.g. cryptopilot)
DATABASE_URL="postgresql://petory:petory@localhost:5433/petory?schema=public"
PORT=8787
JWT_SECRET=change-me-in-production
PUBLIC_BASE_URL=http://localhost:8787

# Volcengine Ark / Seedream — server-side image generation (never ship to client)
ARK_API_KEY=
ARK_API_BASE=https://ark.cn-beijing.volces.com/api/v3
ARK_IMAGE_MODEL=doubao-seedream-4-5-251128

# Kimi / Moonshot — AI chat
KIMI_API_KEY=
KIMI_API_BASE=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k

# Magic Link login (Resend)
RESEND_API_KEY=
MAIL_FROM="Petory <noreply@petory.chat>"

# Authorized administrator email. Other admin-role accounts are disabled on startup.
ADMIN_EMAIL=geyaovip@163.com

# Read-only operator (seeded on first boot if missing)
OPERATOR_EMAIL=operator@petory.app
