{
  "name": "petory",
  "version": "2.4.3",
  "description": "Upload a photo — let it move into your computer.",
  "author": "Petory",
  "main": "./out/main/index.js",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:stack": "node scripts/dev-stack.mjs",
    "dev:docker": "node scripts/dev-docker.mjs",
    "docker:up": "node scripts/docker-up.mjs",
    "docker:up:api": "docker compose --profile api up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "setup:dev": "npm run setup:rembg && npm run server:install && npm run server:db",
    "setup:rembg": "python3 -c \"from rembg import remove\" 2>/dev/null || pip3 install rembg pillow onnxruntime",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "pack": "npm run sync:brand && npm run build && electron-builder",
    "pack:mac": "npm run sync:brand && npm run build && electron-builder --mac",
    "pack:win": "npm run sync:brand && npm run build && electron-builder --win",
    "qa": "node scripts/qa-release.mjs",
    "qa:smoke": "node scripts/qa-smoke.mjs",
    "sync:brand": "node scripts/sync-brand-assets.mjs",
    "release:sync": "node scripts/sync-release-manifest.mjs",
    "release:prepare": "npm run release:sync && node scripts/copy-update-feed.mjs && npm run qa",
    "website:preview": "npx --yes serve website -p 5180",
    "server:install": "npm install --prefix server",
    "server:dev": "npm run dev --prefix server",
    "server:db:up": "npm run db:up --prefix server",
    "server:db": "npm run db:push --prefix server",
    "server:admin:reset": "npm run admin:reset --prefix server"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "electron-updater": "^6.3.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^34.5.8",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
