# Copy to .env and fill in your keys (never commit .env)

# Petory backend (C2.x) — 也可在客户端「设置 → 后台服务」填写（设置优先）
PETORY_API_BASE_URL=http://localhost:8787

# Optional local-only Seedream fallback when logged out (production uses server ARK_API_KEY)
ARK_API_KEY=
ARK_API_BASE=https://ark.cn-beijing.volces.com/api/v3
ARK_IMAGE_MODEL=doubao-seedream-4-5-251128

# Kimi (Moonshot) — AI chat local fallback
KIMI_API_KEY=
KIMI_API_BASE=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k

# Auto-update feed (production builds only)
# UPDATE_FEED_URL=https://petory.chat/releases
